{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Renderer",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-Iinclude",
                "src/WinMain.cpp",
                "src/Window.cpp",
                "src/WindowsMessageMap.cpp",
                "-o",
                "src/WinMain.exe",
                "-mwindows",
                "-g"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}