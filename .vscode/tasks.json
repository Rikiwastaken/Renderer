{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Resources",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/windres.exe",
            "args": [
                "-i",
                "resource/resources.rc",
                "-o",
                "src/resources.res",
                "-O",
                "coff"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Renderer",
            "type": "shell",
            "dependsOn": "Compile Resources",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-Iinclude",
                "src/WinMain.cpp",
                "src/Window.cpp",
                "src/Exceptions.cpp",
                "src/WindowsMessageMap.cpp",
                "src/Keyboard.cpp",
                "src/Mouse.cpp",
                "src/resources.res",
                "-o",
                "src/WinMain.exe",
                "-mwindows",
                "-g"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:/msys64/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}